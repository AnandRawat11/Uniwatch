# ──────────────────────────────────────────────────────────────────
# Uniwatch — Environment Configuration Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────

# --- Django Core ---
DJANGO_SECRET_KEY=replace-this-with-a-long-random-string-at-least-50-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# --- Database (leave blank to use SQLite in dev) ---
# DATABASE_URL=postgresql://user:password@localhost:5432/univatch_db

# --- Environment mode: "development" or "production" ---
DJANGO_ENV=production
